PORT=3000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=studydigest
DB_USER=postgres
DB_PASSWORD=postgres

# JWT
JWT_SECRET=change-this-to-a-random-secret
JWT_EXPIRES_IN=24h

# LLM Microservice
LLM_BASE_URL=https://localhost:8000

# TLS certificates (defaults to backend/certs/localhost.{key,crt} — generate via README step 0)
# TLS_KEY_PATH=
# TLS_CERT_PATH=

# Upload
MAX_FILE_SIZE_MB=10
